<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Phase 1 dev build: NON-sandboxed. A global CGEventTap is effectively
         incompatible with App Sandbox; sandboxing is a ship-time concern.
         Hardened Runtime is ON (see project.yml), so these resource-access
         entitlements are still required for camera/mic under hardened runtime. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <key>com.apple.security.device.camera</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- DEV ONLY (remove before shipping): lets the Hardened Runtime load libraries
         signed by a different Team ID — required for InjectionIII's macOSInjection.bundle
         and the recompiled dylibs it dlopen()s for hot reload. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
